<style>
  /* Verticals carousel: an endless belt that scrolls left through a fixed
     centre; the card passing through that centre lightens. */
  .vcarousel {
    width: 100%;
    overflow: hidden;
  }
  .vtrack {
    display: flex;
    gap: 45px;
    width: max-content;
    margin: 0;
    padding: 0;
    list-style: none;
    will-change: transform;
  }
  .v-glow {
    opacity: 0;
    transition: opacity 0.45s ease;
  }
  .v-item.is-center .v-glow {
    opacity: 1;
  }
</style>

<script>
  // Verticals carousel: an endless belt scrolling left. The list is rendered
  // twice, so wrapping by one set width is seamless. The card nearest the fixed
  // centre gets .is-center and lightens as it passes through.
  document.querySelectorAll<HTMLElement>('.vcarousel').forEach((car) => {
    const track = car.querySelector<HTMLElement>('.vtrack');
    if (!track) return;
    const items = Array.from(track.querySelectorAll<HTMLElement>('.v-item'));
    if (items.length < 2) return;

    const half = Math.floor(items.length / 2);
    const period = items[half].offsetLeft - items[0].offsetLeft;
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const SPEED = 50; // px per second

    let offset = 0, last = 0, paused = false;
    car.addEventListener('pointerenter', () => { paused = true; });
    car.addEventListener('pointerleave', () => { paused = false; });

    const markCentre = () => {
      const box = car.getBoundingClientRect();
      const mid = box.left + box.width / 2;
      let best = items[0], bestD = Infinity;
      for (const it of items) {
        const r = it.getBoundingClientRect();
        const d = Math.abs(r.left + r.width / 2 - mid);
        if (d < bestD) { bestD = d; best = it; }
      }
      for (const it of items) it.classList.toggle('is-center', it === best);
    };

    const frame = (now: number) => {
      if (!last) last = now;
      const dt = Math.min(0.05, (now - last) / 1000);
      last = now;
      if (!paused && !reduce && period > 0) {
        offset = (offset + SPEED * dt) % period;
        track.style.transform = `translateX(${-offset}px)`;
      }
      markCentre();
      requestAnimationFrame(frame);
    };
    requestAnimationFrame(frame);
  });
</script>
