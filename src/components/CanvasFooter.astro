---

<footer
  style="position:absolute;bottom:0;left:0;width:1920px;background:#070128;padding:100px 195px;z-index:30"
>
  <div style="display:flex;gap:197px;align-items:flex-start;width:1530px">
    <div style="display:flex;flex-direction:column;justify-content:space-between;height:441px;width:453px">
      <div style="display:flex;flex-direction:column;gap:29px">
        <a href="/" style="display:flex;gap:10px;align-items:center;cursor:pointer">
          <span
            aria-hidden="true"
            style="background:#895dff;display:flex;align-items:center;justify-content:center;border-radius:9px;width:36px;height:36px;font-family:var(--font-manrope);font-weight:700;font-size:13px;color:#130d00"
            >RM</span
          >
          <span style="font-family:var(--font-manrope);font-weight:700;font-size:18px;color:#fff"
            >Rovex <span style="color:#895dff">Media</span></span
          >
        </a>
        <p style="font-size:14px;line-height:1.8;color:rgba(255,255,255,0.5)">
          Premium performance media buying for the world's most ambitious advertisers and
          affiliate partners. Built for scale. Optimised for ROI.
        </p>
      </div>

      <ul style="display:flex;gap:10px;align-items:center;list-style:none;margin:0;padding:0">
        {footer.socials.map((s) => (
          <li>
            <a
              class="social"
              href={s.href}
              aria-label={s.label}
              rel={s.href.startsWith('http') ? 'noopener' : undefined}
              target={s.href.startsWith('http') ? '_blank' : undefined}
              style="background:#070128;border:1px solid #fff;border-radius:14.857px;width:65px;height:65px;display:flex;align-items:center;justify-content:center"
              set:html={socialSvg[s.icon as keyof typeof socialSvg]}
            />
          </li>
        ))}
      </ul>

      <p style="font-size:14px;line-height:24px;letter-spacing:0.49px;color:rgba(255,255,255,0.5)">
        © 2026 Rovex Media. All rights reserved. rhine-media.com
      </p>
    </div>

    <div style="display:flex;flex-direction:column;gap:91px;width:649px">
      <div style="display:flex;gap:134px;align-items:flex-start">
        {footer.columns.map((col) => (
          <nav aria-label={col.heading} style="display:flex;flex-direction:column;gap:21px">
            <p style="font-weight:600;font-size:12px;letter-spacing:0.96px;text-transform:uppercase;color:#edf0fa;white-space:nowrap">{col.heading}</p>
            <div style="display:flex;flex-direction:column;gap:13px;font-size:14px;line-height:24px;color:rgba(255,255,255,0.5)">
              {col.links.map((l) => (
                <a class="flink" href={l.href} style="color:inherit;white-space:nowrap">{l.label}</a>
              ))}
            </div>
          </nav>
        ))}
      </div>

      <nav
        aria-label="Legal"
        style="display:flex;gap:50px;font-size:14px;line-height:24px;letter-spacing:0.49px;color:rgba(255,255,255,0.5)"
      >
        {footer.legal.map((l) => (
          <a class="flink" href={l.href} style="color:inherit">{l.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>
